# ===========================================
# نجوا (Najva) Messenger - Configuration
# ===========================================

# Database
POSTGRES_USER=najva
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=najva
DATABASE_URL=postgresql://najva:change_me_in_production@postgres:5432/najva

# Redis
REDIS_URL=redis://redis:6379

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost

# WebAuthn / passkeys (docs/ENCRYPTION.md flow B)
# WEBAUTHN_RP_ID: the registrable domain (no scheme/port). localhost for dev.
# WEBAUTHN_ORIGIN: the exact browser origin (scheme + host [+ port]). The client
#   is served on port 80, so no explicit :80 suffix. Set to your https:// domain
#   in production (e.g. WEBAUTHN_RP_ID=najva.example.com,
#   WEBAUTHN_ORIGIN=https://najva.example.com).
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Najva Messenger
WEBAUTHN_ORIGIN=http://localhost

# File Storage
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=104857600
DEFAULT_STORAGE_LIMIT=524288000

# Admin Account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# TURN Server
TURN_SERVER_URL=turn:turn:3478
TURN_SERVER_TLS_URL=turns:turn:5349
TURN_USERNAME=najva
TURN_PASSWORD=najva_turn_password

# mediasoup
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_PORT=4443

# Calls / SFU (Module D). MEDIA_JWT_SECRET is shared by the main server (signs
# media grants) and the media-server (verifies them). TURN_SECRET is coturn's
# static-auth-secret for time-limited REST credentials.
MEDIA_JWT_SECRET=change-me-media-grant-secret
TURN_SECRET=change-me-turn-static-auth-secret
TURN_URLS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp,turns:localhost:5349?transport=tcp
STUN_URLS=stun:localhost:3478
MEDIA_SERVER_URL=http://localhost:4443

# Notifications (Module F). Generate VAPID keys once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# FCM/APNs are config-gated adapters (empty = no-op, for future native clients).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@najva.local
FCM_SERVER_KEY=
APNS_KEY=

# Nginx
NGINX_HOST=localhost
