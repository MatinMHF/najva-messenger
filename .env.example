# ============================================================
# Najva Messenger — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ----- PostgreSQL -----
POSTGRES_USER=najva
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=najva
DATABASE_URL=postgresql://najva:change_me_strong_password@postgres:5432/najva

# ----- Redis -----
REDIS_URL=redis://redis:6379

# ----- JWT (generate with: openssl rand -hex 32) -----
JWT_SECRET=change_me_32_random_bytes_minimum
JWT_REFRESH_SECRET=change_me_another_32_random_bytes

# ----- Server -----
PORT=3000
NODE_ENV=production
CORS_ORIGIN=http://localhost
UPLOAD_DIR=/app/uploads
# Max upload size in bytes (default: 100 MB)
MAX_FILE_SIZE=104857600
# Per-user storage limit in bytes (default: 500 MB)
DEFAULT_STORAGE_LIMIT=524288000

# ----- mediasoup SFU -----
# Set this to your server's public IP for production
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_PORT=4443

# ----- TURN Server (coturn) -----
# Used in turn/turnserver.conf — must match
TURN_SECRET=change_me_turn_secret
